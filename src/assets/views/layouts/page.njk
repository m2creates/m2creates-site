{% extends "layouts/base.njk" %}

{% block content %}

<article>

  {# ══════════════════════════════════════════════════════════ #}
  {# HERO                                                       #}
  {# ══════════════════════════════════════════════════════════ #}
  <section class="relative flex flex-col pb-12 overflow-hidden pt-28"
          aria-labelledby="hero-heading">

    {# Ghost background m² #}
    <span class="hidden lg:block absolute right-[-0.04em] top-1/2 -translate-y-[48%]
                font-display font-semibold italic select-none pointer-events-none
                leading-none text-[20vw] text-transparent
                h-enter-fade d-7"
          aria-hidden="true"
          style="-webkit-text-stroke: 1px #C9BCA9;">m²</span>

    {# Coordinate watermark #}
    <div class="hidden md:block absolute top-32 right-14
                font-code text-[0.58rem] tracking-wider
                text-[#C9BCA9] text-right leading-loose
                h-enter-fade d-7"
        aria-hidden="true">
      30.2672° N<br>97.7431° W<br>Austin, TX
    </div>

    {# Main hero content #}
    <div class="flex flex-col justify-center flex-1 max-w-4xl px-6 mx-auto md:px-14">

      <p class="h-enter d-1 font-code text-[0.6rem] tracking-[0.2em] uppercase text-[#1C5B72] mb-7">
        {{ subtitle }}
      </p>

      <h1 id="hero-heading"
          class="h-enter d-2 font-display font-light italic leading-[1.05] text-[#1A1510] mb-8"
          style="font-size: clamp(2.8rem, 8vw, 6.2rem); letter-spacing: -0.015em;">
        {{ title }}
      </h1>

      {% if tldr %}
      <p class="h-enter d-3 font-display text-[#4A4035] mb-10"
        style="font-size: clamp(1rem, 2.2vw, 1.45rem); letter-spacing: 0.01em;">
        {{ tldr }}
      </p>
      {% endif %}

    </div>

  </section>

  <hr class="border-none h-px bg-gradient-to-r from-transparent via-[#C9BCA9] to-transparent">
  {% if showTravel %}
    {% include "partials/travel.njk" %}
  {% endif %}
  <section class="px-6 md:px-14 py-12 space-y-5 font-reading text-[1rem] leading-[1.85] text-[#4A4035] max-w-4xl mx-auto prose">

  <!-- Content -->
  {{ content | safe }}

  </section>

  <section class="px-6 md:px-14 py-12 space-y-5 font-reading text-[1rem] leading-[1.85] text-[#4A4035] max-w-4xl mx-auto">
    {% if showProjects %}
      {% set postslist = collections.projects %}
      {% include "components/list/list-projects.njk" %}
    {% endif %}
  </section>

</article>

{% endblock %}
