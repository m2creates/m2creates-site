{# ══════════════════════════════════════════════════════════ #}
{# PROJECT LINKS BAR                                          #}
{# Drop in post.njk after the hero divider when links exist.  #}
{#                                                            #}
{# Frontmatter schema:                                        #}
{#   links:                                                   #}
{#     - label: Google Sheets                                 #}
{#       desc: Calculator + raw data + SKU summary            #}
{#       url: https://...                                     #}
{#       type: sheets                                         #}
{#     - label: Looker Studio Dashboard                       #}
{#       desc: 3 panels — replenishment queue, carrying cost  #}
{#       url: https://...                                     #}
{#       type: looker                                         #}
{#                                                            #}
{# Supported types: sheets, looker, github, gitlab,           #}
{#   figma, live, pdf, drive, airtable                        #}
{# Any unknown type renders a neutral grey icon.             #}
{# ══════════════════════════════════════════════════════════ #}

{% if links and links.length %}

<div class="border-b border-[#C9BCA9] bg-[#EDE5D4]">
  <div class="flex flex-wrap items-stretch max-w-5xl gap-0 px-6 mx-auto md:px-14">

    {# Link items #}
    {% for link in links %}

    {# ── Resolve icon color and SVG by type ── #}
    {% if link.type == "sheets" %}
      {% set iconBg = "#0f9d58" %}
      {% set iconSvg %}
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 1.5L18.5 9H13V3.5zM8 13h8v1.5H8V13zm0 3h5v1.5H8V16zm0-6h8v1.5H8V10z"/>
      {% endset %}

    {% elif link.type == "looker" %}
      {% set iconBg = "#4285f4" %}
      {% set iconSvg %}
        <circle cx="12" cy="12" r="3.5"/><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 17.5c-4.14 0-7.5-3.36-7.5-7.5S7.86 4.5 12 4.5s7.5 3.36 7.5 7.5-3.36 7.5-7.5 7.5z"/>
      {% endset %}

    {% elif link.type == "github" %}
      {% set iconBg = "#24292e" %}
      {% set iconSvg %}
        <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
      {% endset %}

    {% elif link.type == "gitlab" %}
      {% set iconBg = "#fc6d26" %}
      {% set iconSvg %}
        <path d="M22.65 14.39L12 22.13 1.35 14.39a.84.84 0 0 1-.3-.94l1.22-3.78 2.44-7.51A.42.42 0 0 1 4.82 2a.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.49h8.1l2.44-7.51A.42.42 0 0 1 18.6 2a.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.51L23 13.45a.84.84 0 0 1-.35.94z"/>
      {% endset %}

    {% elif link.type == "figma" %}
      {% set iconBg = "#a259ff" %}
      {% set iconSvg %}
        <path d="M8 24c2.2 0 4-1.8 4-4v-4H8c-2.2 0-4 1.8-4 4s1.8 4 4 4z"/><path d="M4 12c0-2.2 1.8-4 4-4h4v8H8c-2.2 0-4-1.8-4-4z"/><path d="M4 4c0-2.2 1.8-4 4-4h4v8H8C5.8 8 4 6.2 4 4z"/><path d="M12 0h4c2.2 0 4 1.8 4 4s-1.8 4-4 4h-4V0z"/><path d="M20 12c0 2.2-1.8 4-4 4s-4-1.8-4-4 1.8-4 4-4 4 1.8 4 4z"/>
      {% endset %}

    {% elif link.type == "drive" %}
      {% set iconBg = "#1fa463" %}
      {% set iconSvg %}
        <path d="M6.6 2l-5 8.7h5l5-8.7zm5 0l5 8.7H22l-5-8.7zM2 12l4 7h12l4-7z"/>
      {% endset %}

    {% elif link.type == "airtable" %}
      {% set iconBg = "#18bfff" %}
      {% set iconSvg %}
        <path d="M11.99 1.388L2.35 5.351a.73.73 0 0 0 0 1.34l9.64 3.965a.73.73 0 0 0 .546 0l9.64-3.964a.73.73 0 0 0 0-1.341zm0 0"/><path d="M13.09 13.67v7.772a.729.729 0 0 0 1.007.676l8.274-3.5a.73.73 0 0 0 .453-.676v-7.77a.729.729 0 0 0-1.007-.677l-8.274 3.5a.73.73 0 0 0-.453.676zm0 0"/><path d="M10.34 14.348l-2.49 1.195-.262.124-5.218 2.49A.73.73 0 0 1 1.176 17.5V9.762a.727.727 0 0 1 .421-.661.71.71 0 0 1 .306-.064.72.72 0 0 1 .442.148l.035.03 7.742 6.13a.46.46 0 0 1 .218-.997zm0 0"/>
      {% endset %}

    {% elif link.type == "pdf" %}
      {% set iconBg = "#e53935" %}
      {% set iconSvg %}
        <path d="M20 2H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-8.5 7.5c0 .83-.67 1.5-1.5 1.5H9v2H7.5V7H10c.83 0 1.5.67 1.5 1.5v1zm5 2c0 .83-.67 1.5-1.5 1.5h-2.5V7H15c.83 0 1.5.67 1.5 1.5v3zm4-3H19v1h1.5V11H19v2h-1.5V7h3v1.5zM9 9.5h1v-1H9v1zM4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm10 5.5h1v-3h-1v3z"/>
      {% endset %}

    {% else %}
      {# Generic / live site #}
      {% set iconBg = "#4a8c82" %}
      {% set iconSvg %}
        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
      {% endset %}
    {% endif %}

    <a href="{{ link.url }}"
      {% if link.url and 'melaniemagdalena.com' not in link.url and link.url[0] != '/' %}
        target="_blank" rel="noopener noreferrer"
      {% endif %}
      class="flex items-center gap-3 px-6 py-4
              border-r border-[#C9BCA9] last:border-r-0
              hover:bg-[#1a2420]/[0.04] transition-colors
              no-underline group">

      {# Colored icon square #}
      <div class="w-7 h-7 rounded-[3px] flex items-center justify-center flex-shrink-0"
           style="background: {{ iconBg }};">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"
             class="w-3.5 h-3.5" fill="white">
          {{ iconSvg | safe }}
        </svg>
      </div>

      {# Label + description #}
      <div>
        <span class="font-code text-[0.65rem] font-medium tracking-[0.1em] uppercase
                     text-[#1A1510] block leading-none mb-1
                     group-hover:text-[#1C5B72] transition-colors">
          {{ link.label }}
        </span>
        {% if link.desc %}
        <span class="font-code text-[0.58rem] tracking-wide text-[#8a8478] block">
          {{ link.desc }}
        </span>
        {% endif %}
      </div>

      {# Arrow #}
      <span class="font-code text-[0.7rem] text-[#7a9e8e] ml-auto pl-4
                   group-hover:text-[#1C5B72] transition-colors"
            aria-hidden="true">↗</span>

    </a>
    {% endfor %}

  </div>
</div>

{% endif %}
